# ─── App ────────────────────────────────────────────────────────────────────
NODE_ENV=development
APP_URL=http://localhost:3000

# ─── PostgreSQL ──────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/ragsaas

# ─── Redis ───────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ─── Google Gemini ───────────────────────────────────────────────────────────
# Get your key at: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your-gemini-api-key
GEMINI_EMBEDDING_MODEL=text-embedding-004
GEMINI_CHAT_MODEL=gemini-2.0-flash

# ─── Pinecone ────────────────────────────────────────────────────────────────
PINECONE_API_KEY=your-pinecone-api-key
PINECONE_INDEX_NAME=support-docs
PINECONE_ENVIRONMENT=gcp-starter

# ─── Kafka ───────────────────────────────────────────────────────────────────
KAFKA_BROKERS=localhost:9092
KAFKA_CLIENT_ID=rag-support-api

# ─── JWT ─────────────────────────────────────────────────────────────────────
# Generate with: openssl rand -hex 32
JWT_SECRET=change-me-use-openssl-rand-hex-32
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# ─── API Key hashing ─────────────────────────────────────────────────────────
API_KEY_SALT=10

# ─── AWS ─────────────────────────────────────────────────────────────────────
AWS_REGION=ap-south-1
S3_BUCKET=rag-support-docs-prod

# ─── RAG pipeline ────────────────────────────────────────────────────────────
RETRIEVAL_SCORE_THRESHOLD=0.75
RETRIEVAL_TOP_K=5
CONTEXT_WINDOW_TURNS=6
